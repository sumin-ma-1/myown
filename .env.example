# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
# (선택) 추가 화이트리스트. 비우면 웹 대시보드 → 연동 APP에서 Telegram 연결로 등록합니다.
ALLOWED_TELEGRAM_USER_IDS=

# Database
# Windows에 PostgreSQL이 설치되어 있으면 5432 충돌 → 5433 사용
DATABASE_URL=postgresql://myown:myown@localhost:5433/myown

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# LLM (optional — natural language without commands)
#
# Option A: Remote Ollama via SSH tunnel
#   ssh -L 11434:localhost:11434 user@your-server
#   LLM_BASE_URL=http://localhost:11434/v1
#   LLM_MODEL=gemma2:9b
#   OPENAI_API_KEY=ollama
#
# Option B: OpenAI cloud
#   OPENAI_API_KEY=sk-...
#   LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=gemma4:e4b
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# App
TIMEZONE=Asia/Seoul
REMINDER_HOUR=9
NODE_ENV=development

# Webhook (production). Leave empty for long polling in dev.
WEBHOOK_URL=
WEBHOOK_PORT=3000

# Web dashboard API
WEB_API_PORT=4000
WEB_CORS_ORIGIN=http://localhost:5173
WEB_APP_URL=http://localhost:5173

# Auth (closed beta) — Google 로그인 전용
# Google Cloud Console → OAuth 2.0 클라이언트 ID (웹 애플리케이션)
# 승인된 리디렉션 URI: http://localhost:5173/api/auth/google/callback
GOOGLE_CLIENT_ID= # 우리 서비스의 Google 측 앱 식별번호
GOOGLE_CLIENT_SECRET= # 우리 서버가 Google에 보여주는 앱 비밀번호 같은 비밀키
GOOGLE_REDIRECT_URI=http://localhost:5173/api/auth/google/callback
# Calendar 연동 — Google Console에서 Calendar API 활성화 + 리디렉션 URI 추가:
#   http://localhost:5173/api/integrations/google-calendar/callback
GOOGLE_CALENDAR_REDIRECT_URI=

# 관리자 이메일 — 초대코드 없이 Google 가입 가능, /admin 접근
ADMIN_EMAILS=you@example.com
SESSION_TTL_DAYS=30

# Kakao Open Builder (선택 — 카카오톡 채널 메신저 연동)
# 카카오톡 채널 관리자센터 → 채널 URL (예: https://pf.kakao.com/_xxxxx)
KAKAO_CHANNEL_URL=
# 오픈빌더 봇 이름 (안내 문구용, 선택)
KAKAO_BOT_NAME=MyOwn
