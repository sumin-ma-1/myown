# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
# (선택) 추가 화이트리스트. 비우면 웹 대시보드 → 연동 APP에서 Telegram 연결로 등록합니다.
ALLOWED_TELEGRAM_USER_IDS=

# Database
# Windows에 PostgreSQL이 설치되어 있으면 5432 충돌 → 5433 사용
DATABASE_URL=postgresql://myown:myown@localhost:5433/myown

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# LLM (optional — natural language without commands)
#
# Option A: Remote Ollama via SSH tunnel
#   ssh -L 11434:localhost:11434 user@your-server
#   LLM_BASE_URL=http://localhost:11434/v1
#   LLM_MODEL=gemma2:9b
#   OPENAI_API_KEY=ollama
#
# Option B: OpenAI cloud
#   OPENAI_API_KEY=sk-...
#   LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=gemma4:e4b
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# App
TIMEZONE=Asia/Seoul
REMINDER_HOUR=9
NODE_ENV=development

# Webhook (production). Leave empty for long polling in dev.
WEBHOOK_URL=
WEBHOOK_PORT=3000

# Attachments (Phase 2)
ATTACHMENT_STORAGE_DIR=
HWP_PARSER_URL=http://localhost:8100
ATTACHMENT_MAX_MB=20
ATTACHMENT_MAX_TEXT_CHARS=50000
# LLM 분석 속도 튜닝 (짧을수록 빠름)
ATTACHMENT_LLM_MAX_CHARS=6000
ATTACHMENT_LLM_TIMEOUT_MS=90000
ATTACHMENT_LLM_MAX_TOKENS=1200
# Web dashboard API
WEB_API_PORT=4000
WEB_API_TOKEN=change-me-to-match-web-api-token
WEB_CORS_ORIGIN=http://localhost:5173
# WEB_USER_TELEGRAM_ID — 더 이상 필요 없음 (웹은 DB에 연동된 사용자를 자동 사용)
